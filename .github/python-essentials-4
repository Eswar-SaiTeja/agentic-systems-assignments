class StudentMarks:
    def __init__(self, marks):
        self.marks = marks

    def last_three_avg(self):
        try:
            avg = sum(self.marks[-3:]) / 3
            print("Average of last 3 marks is:", avg)
        except:
            print("Not enough marks to calculate average")


marks = [50, 60, 70, 80, 90]
s = StudentMarks(marks)
s.last_three_avg()
